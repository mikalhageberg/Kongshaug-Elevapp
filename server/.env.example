# ─────────────────────────────────────────────────────────────
# Kongshaug Brannvakt – konfigurasjon og hemmeligheter
#
# Kopier denne filen til «.env» og fyll inn ekte verdier.
# «.env» er lagt i .gitignore og skal ALDRI committes eller deles.
# ─────────────────────────────────────────────────────────────

# Porten serveren kjører på
PORT=3000

# Hemmelig nøkkel som signerer innloggings-tokens (JWT).
# MÅ endres i produksjon. Lag en lang, tilfeldig streng, f.eks.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=bytt-meg-til-en-lang-tilfeldig-streng

# Sett til "production" når appen kjører på en ekte server (aktiverer Secure-cookies).
NODE_ENV=development

# Hvor databasen og opplastede meny-PDF-er lagres. La stå tom lokalt (bruker
# «server/data»). I drift (Railway o.l.): monter et persistent volum på en enkel
# topp-nivå-sti og sett DATA_DIR til samme sti, f.eks. DATA_DIR=/data.
DATA_DIR=

# ── Første admin-konto (kun ved tom database) ────────────────
# Hvis databasen ikke har noen admin ennå, opprettes én automatisk ved
# oppstart fra disse to. Trygt å la stå etter første oppstart – gjør
# ingenting så snart en admin finnes. Fjern/tøm gjerne etterpå.
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_FULL_NAME=

# ── Skolens posisjon (brukes for å hindre juks) ──────────────
# Koordinater for Kongshaug Musikkgymnas. Verifiser mot kart!
SCHOOL_LAT=60.18023
SCHOOL_LNG=5.42007
# Hvor mange meter unna skolen en elev kan være og fortsatt regnes som "på området".
SCHOOL_RADIUS_METERS=200

# ── Andakt ──────────────────────────────────────────────────
# Klokkeslett (HH:MM) for når oppmøte etter dette regnes som "for sent".
ANDAKT_DEADLINE=08:10
# Hvor lenge (sekunder) en skannet QR-kode er gyldig etter at den vises.
# QR-koden roterer, så en avfotografert kode blir ubrukelig etter dette.
ANDAKT_QR_TTL_SECONDS=45

# ── Feide / Itslearning-innlogging (valgfritt) ───────────────
# La disse stå tomme til skolen har registrert tjenesten i Feide Kundeportal.
# Når CLIENT_ID og CLIENT_SECRET er satt, dukker «Logg inn med Feide» opp.
# Se FEIDE-SETUP.md for stegvis oppskrift.
FEIDE_CLIENT_ID=
FEIDE_CLIENT_SECRET=
FEIDE_REDIRECT_URI=http://localhost:3000/api/auth/feide/callback
FEIDE_DISCOVERY_URL=https://auth.dataporten.no/.well-known/openid-configuration
# Feide-claim som kobles mot lokalt brukernavn (localpart før @ brukes): email | sub
FEIDE_MATCH_CLAIM=email

# ── OpenAI (tolker ukemeny-PDF til pen visning i appen) ──────
# Lag en nøkkel på platform.openai.com → API keys. Uten nøkkel vises menyen
# fortsatt som PDF, men uten den pene dag-for-dag-visningen i appen.
OPENAI_API_KEY=
# Modell som leser menyen. gpt-4.1-mini er billig og god nok til dette.
OPENAI_MENU_MODEL=gpt-4.1-mini

# ── E-post via Brevo (for automatisk utsending av brannlisten) ──
# Lag en konto på brevo.com, generer en API-nøkkel (SMTP & API → API Keys),
# og verifiser avsender-adressen (MAIL_FROM) under «Senders».
# Mottaker, klokkeslett og av/på styres i admin → Innstillinger.
BREVO_API_KEY=
MAIL_FROM=brannvakt@kongshaug.no
MAIL_FROM_NAME=Kongshaug Brannvakt
