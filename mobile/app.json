{
  "expo": {
    "name": "Kongshaug Elevapp",
    "slug": "kongshaug-elevapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "backgroundColor": "#1e3a5f",
    "icon": "./assets/icon.png",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "no.kongshaug.elevapp",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Appen bruker kamera for å skanne QR-koden til andakt.",
        "NSLocationWhenInUseUsageDescription": "Appen bruker posisjon for å bekrefte at du er på skolen.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "no.kongshaug.elevapp",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#20303A"
      },
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Appen bruker kamera for å skanne QR-koden til andakt."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Appen bruker posisjon for å bekrefte at du er på skolen."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Appen bruker Face ID for å låse opp når du åpner den."
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "apiUrl": "https://elevapp.online",
      "eas": {
        "projectId": "316b5f66-d91b-46be-81e5-fb7b47b682ac"
      }
    },
    "owner": "mikalhageberg"
  }
}
